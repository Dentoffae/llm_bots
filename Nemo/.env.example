# Telegram bot token — get it from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Language model to use (default: gpt-4o-mini)
MODEL_NAME=gpt-4o-mini

# Number of messages to keep in context (default: 20)
MAX_HISTORY=20

# Max tokens in the model response (default: 3000)
MAX_TOKENS=3000

# Response creativity: 0.0 (focused) — 2.0 (creative) (default: 0.7)
TEMPERATURE=0.7

# Console log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO

# System prompt — defines the bot's personality and behaviour
SYSTEM_PROMPT=You are Nemo, a friendly and helpful assistant with a great memory. Use the conversation history to give contextual and relevant answers.
